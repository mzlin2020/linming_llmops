# =============================================================================
# linming_llmops 配置
#
# 一键部署三步：
#   1) cp deploy/.env.example deploy/.env
#   2) 编辑下面【必填】三项（生产务必改成随机长串）
#   3) docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d --build
#      → 浏览器打开 http://127.0.0.1:8080 （端口由 FRONTEND_PORT 决定）
#
# 你「只需要」改【必填】块；想用对话/RAG 再填【对话/RAG】块。其余留空即用内置默认。
# 完整可调项（配额 / 嵌入 / 工作流边界 / 服务进程数…）见 deploy/README.md「完整变量参考」。
# =============================================================================

TZ=UTC

# -----------------------------------------------------------------------------
# 【必填】生产务必改成随机长串
# -----------------------------------------------------------------------------
# 登录令牌签名密钥；留空后端登录会直接报错
JWT_SECRET=
# provider/渠道 API Key 落库加密（留空回落 JWT_SECRET；更换会让已存密文解不开，需重填 key）
AI_SECRET_ENCRYPT_KEY=
# 数据库密码（app 侧自动复用此值，无需再填别处）
MYSQL_ROOT_PASSWORD=changeme

# -----------------------------------------------------------------------------
# 【对话 / RAG】填了才能聊天 / 用 LLM 检索
# 嵌入走本地模型，建库/检索本身不需要付费 key（首启会下载嵌入模型权重）
# -----------------------------------------------------------------------------
# OpenAI 或兼容端点的 key
OPENAI_API_KEY=
# 自建/中转兼容端点；留空走 OpenAI 官方
OPENAI_BASE_URL=
DEFAULT_LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# 【常用可选】按需取消注释 / 修改
# -----------------------------------------------------------------------------
# 前端对外端口（用 80 需特权端口；公网暴露再设 FRONTEND_BIND=0.0.0.0）
FRONTEND_PORT=8080

# 国内网络加速（下载/构建慢时启用）
# HF_ENDPOINT=https://hf-mirror.com
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 向量库鉴权（默认无鉴权；生产建议填非空随机串。注意：填了两边都得非空）
QDRANT_API_KEY=

# 其他 LLM 供应商（可选；不填即不启用）
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
VOLCENGINE_ARK_API_KEY=

# 「设置→模型」写入面（可增删改 provider / 填 key）。本项目无管理员概念，默认关
ENABLE_LLM_ADMIN=false

# 本地 ML 嵌入栈（真实 RAG 需要，约 +1.5GB）。false=轻镜像但无本地向量检索
INSTALL_ML=true

# 内置工具凭证（可选，未填则该工具被安全跳过）
# SERPER_API_KEY=

# -----------------------------------------------------------------------------
# 其余所有项（配额 / 聊天附件 / 工作流边界 / 嵌入参数 / 存储 / 服务进程数 / 图像·TTS…）
# 均有合理默认，留空即可；需细调见 deploy/README.md「完整变量参考」。
# -----------------------------------------------------------------------------
