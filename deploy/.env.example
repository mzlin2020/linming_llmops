# =============================================================================
# linming_llmops 环境配置模板
# 用法：cp deploy/.env.example deploy/.env  然后按需修改
#
# 说明：本模板为「目标形态」。部分键（存储适配器、认证、图像/TTS）会在对应
# 开发阶段才真正接线（详见 docs/开发指南.md）；此处先给齐，便于一处配置。
# 凡留空的密钥类项目，未填写即视为该功能未启用。
# =============================================================================

# -----------------------------------------------------------------------------
# 时区
# -----------------------------------------------------------------------------
TZ=UTC

# -----------------------------------------------------------------------------
# 基础设施 —— docker-compose 容器侧（compose 文件用这些起 MySQL/Redis/Qdrant）
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=linming_llmops
MYSQL_PORT=3306
REDIS_PORT=6379
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# Qdrant 鉴权密钥（留空=不鉴权）；生产建议填一个随机串
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# 基础设施 —— 应用侧（后端从这些读取连接信息；host 用 compose 服务名）
# -----------------------------------------------------------------------------
mysql_server_host=mysql
mysql_server_port=3306
mysql_server_username=root
mysql_server_password=changeme
mysql_server_database=linming_llmops
# 留空则由上面字段拼装；需要时可整串覆盖
SQLALCHEMY_DATABASE_URI=
SQLALCHEMY_POOL_SIZE=30
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_ECHO=False

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=2
REDIS_USE_SSL=False

# Celery（复用 Redis，逻辑库错开）
CELERY_BROKER_DB=3
CELERY_RESULT_BACKEND_DB=4
CELERY_TASK_IGNORE_RESULT=False
CELERY_RESULT_EXPIRES=3600
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=True

QDRANT_HOST=qdrant
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=False
QDRANT_DATASET_COLLECTION=ai_dataset

# -----------------------------------------------------------------------------
# 认证（自建轻量登录，无管理员概念）
# -----------------------------------------------------------------------------
# JWT 签名密钥（自有，与任何外部系统无关）；务必改成随机长串
JWT_SECRET=
JWT_ALGORITHM=HS256
# 令牌有效期（秒）：access 默认 7 天，refresh 默认 30 天
JWT_ACCESS_TOKEN_EXPIRES=604800
JWT_REFRESH_TOKEN_EXPIRES=2592000
# 是否开放自助注册（true/false）；关闭后仅能用已存在/预置账号登录
ALLOW_REGISTRATION=true
# 可选：首次启动种子账号（设了就在迁移后幂等创建一个账号）
BOOTSTRAP_ACCOUNT_EMAIL=
BOOTSTRAP_ACCOUNT_PASSWORD=
# 落库 provider/渠道 API Key 的加密密钥材料（留空则回落 JWT_SECRET）。
# ⚠ 更换它会导致已存的密文解不开，需后台重填 key。
AI_SECRET_ENCRYPT_KEY=
WTF_CSRF_ENABLED=False

# -----------------------------------------------------------------------------
# LLM 供应商（默认 OpenAI 兼容；其余为可选）
# -----------------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# 自建/中转 OpenAI 兼容端点可填，留空走官方
OPENAI_BASE_URL=

# 可选：Anthropic（langchain-anthropic 默认读 ANTHROPIC_API_KEY）
ANTHROPIC_API_KEY=

# 可选：DeepSeek 官方
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：火山方舟 Ark（需中国账号；不填则不启用）
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# 多渠道兜底熔断（仅 multi_channel provider 生效）
CHANNEL_FAILURE_THRESHOLD=3
CHANNEL_COOLDOWN_SECONDS=300

# Agent 运行时
AGENT_MAX_ITERATIONS=5

# -----------------------------------------------------------------------------
# 嵌入模型（知识库向量化，本地 sentence-transformers）
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# bge-small-zh-v1.5 输出 512 维；改模型必须同步改它并重建 collection
EMBEDDING_VECTOR_SIZE=512
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=True
EMBEDDING_QUERY_INSTRUCTION=为这个句子生成表示以用于检索相关文章：
EMBEDDING_QUERY_PROMPT_NAME=
# HuggingFace 缓存目录与镜像（留空用默认；国内可设 HF_ENDPOINT=https://hf-mirror.com）
HF_HOME=
HF_ENDPOINT=

# -----------------------------------------------------------------------------
# 文件/图片存储（默认本地磁盘，替换原网关服务的 OSS 委托）
# 存储适配器在 Phase 4 接线；S3/MinIO 为可选后端。
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_ROOT=storage
# 对外可访问的文件基地址（/files 静态路由用，Phase 4 接线）
FILES_BASE_URL=
UPLOAD_ALLOWED_EXTENSIONS=txt,md,markdown,pdf,docx,csv,xlsx
UPLOAD_MAX_SIZE=15728640

# 可选：S3 / MinIO 后端（STORAGE_BACKEND=s3 时启用）
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# 配额与特性限制
# 注意：本项目无管理员概念，配额对所有账号统一生效（拍平在 Phase 4 实现）。
# -----------------------------------------------------------------------------
QUOTA_MAX_DATASETS_PER_USER=3
QUOTA_MAX_DOCS_PER_DATASET=5
QUOTA_USER_UPLOAD_MAX_SIZE=2097152
QUOTA_BUILD_DAILY_LIMIT=3
QUOTA_BUILD_COOLDOWN_SECONDS=600
QUOTA_HIT_PER_MINUTE=10
QUOTA_HIT_DAILY_LIMIT=100
QUOTA_OPENAPI_PER_MINUTE=10
QUOTA_OPENAPI_DAILY_LIMIT=30
QUOTA_CHAT_ATTACHMENTS_PER_DAY=2
QUOTA_MAX_WORKFLOWS_PER_USER=3
QUOTA_WORKFLOW_DEBUG_DAILY_LIMIT=20
QUOTA_IMAGE_DAILY_LIMIT=100
QUOTA_TTS_DAILY_LIMIT=2
OPENAPI_HISTORY_MAX_TURNS=3

# 聊天附件（图片多模态 + 文档文本注入）
CHAT_MAX_IMAGES_PER_MESSAGE=3
CHAT_MAX_FILES_PER_MESSAGE=2
CHAT_DOC_DOWNLOAD_MAX_BYTES=10485760
CHAT_DOC_TEXT_MAX_CHARS=20000

# 工作流运行边界（v1.1 暴露；引擎随核心移植）
WORKFLOW_MAX_NODES=20
WORKFLOW_HTTP_TIMEOUT=10
WORKFLOW_HTTP_MAX_RESPONSE_BYTES=1048576
WORKFLOW_LLM_MAX_TOKENS=1024
WORKFLOW_CODE_TIMEOUT_SECONDS=5
WORKFLOW_CODE_MAX_OUTPUT_BYTES=65536

# -----------------------------------------------------------------------------
# 图像生成 / TTS（可选，v1.1；未配置则功能关闭）
# 默认实现依赖火山引擎（需中国账号）；后续做成供应商可插拔。
# -----------------------------------------------------------------------------
DEFAULT_IMAGE_PROVIDER=volcengine_seedream
DEFAULT_IMAGE_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_ARK_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

DEFAULT_TTS_PROVIDER=volcengine_tts
DEFAULT_TTS_MODEL=doubao-tts-2-0
DEFAULT_TTS_VOICE=zh_female_vv_uranus_bigtts
VOLCENGINE_TTS_API_KEY=
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# 运行时（应用容器，Phase 1+ 生效）
# -----------------------------------------------------------------------------
PORT=5001
SERVER_BIND_HOST=0.0.0.0
MODE=api
MIGRATION_ENABLED=false
FLASK_ENV=production
SERVER_WORKER_AMOUNT=2
SERVER_WORKER_CLASS=gthread
SERVER_THREAD_AMOUNT=4
GUNICORN_TIMEOUT=600
CELERY_POOL=prefork
CELERY_CONCURRENCY=5
CELERY_LOG_LEVEL=INFO
